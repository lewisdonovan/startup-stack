# ============================================================
# Startup Stack — Environment Variables Template
# ============================================================
# Copy this to .env (bootstrap does this automatically).
# Never commit .env to git. Treat .env as the vault for
# bootstrap-created account passwords (*_ACCOUNT_PASSWORD).
# ============================================================

# ── Always Active ──────────────────────────────────────────
OPENROUTER_API_KEY=
# OPENROUTER_ACCOUNT_PASSWORD=
CONTEXT7_API_KEY=

# ── Linear ─────────────────────────────────────────────────
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=
# LINEAR_ACCOUNT_PASSWORD=

# ── Notion ─────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_INTEGRATION_TYPE=Internal
# NOTION_ACCOUNT_PASSWORD=

# ── Resend ─────────────────────────────────────────────────
RESEND_API_KEY=
# RESEND_ACCOUNT_PASSWORD=

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
# SUPABASE_ACCOUNT_PASSWORD=

# ── n8n ────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
# N8N_ACCOUNT_PASSWORD=
