# ============================================================
# Startup Stack — Environment Variables Template
# ============================================================
# Copy this to .env and fill in your API keys.
# Never commit .env to git.
# ============================================================

# ── Always Active ──────────────────────────────────────────
OPENROUTER_API_KEY=
CONTEXT7_API_KEY=

# ── Linear ─────────────────────────────────────────────────
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=

# ── Slack ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=xbot-...
SLACK_SIGNING_SECRET=
SLACK_TEAM_ID=

# ── Figma ──────────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=

# ── Notion ─────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_INTEGRATION_TYPE=

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ── Resend ─────────────────────────────────────────────────
RESEND_API_KEY=

# ── Xero ───────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REFRESH_TOKEN=
XERO_ORGANIZATION_ID=

# ── Shopify ────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_STORE_DOMAIN=

# ── n8n ────────────────────────────────────────────────────
N8N_BASE_URL=
N8N_API_KEY=

# ── Google Workspace ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── Airtable ───────────────────────────────────────────────
AIRTABLE_ACCESS_TOKEN=
AIRTABLE_ORGANIZATION_ID=