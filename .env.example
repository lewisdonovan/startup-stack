# ============================================================
# Startup Stack — Environment Variables Template
# ============================================================
# Copy this to .env and fill in your API keys.
# Never commit .env to git.
# ============================================================

# ── Always Active ──────────────────────────────────────────
OPENROUTER_API_KEY=
CONTEXT7_API_KEY=

# ── Notion ─────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_INTEGRATION_TYPE=Internal

# ── Resend ─────────────────────────────────────────────────
RESEND_API_KEY=

# ── n8n ────────────────────────────────────────────────────
N8N_BASE_URL=
N8N_API_KEY=